# Database Configuration (Railway will auto-provide this)
DATABASE_URL=postgresql://username:password@localhost:5432/database_name

# AI Configuration (100% FREE - No API keys needed!)
# - Image generation: Pollinations.ai (free, no limits)
# - Text generation: HuggingFace Inference API (free)

# Server Port (Railway will set this automatically)
PORT=3001

# Admin-only endpoint guard (required in production; endpoints return 503 if unset)
ADMIN_SECRET_KEY=

# Optional fallback login, only used when DATABASE_URL is not connected (login is disabled if unset)
FALLBACK_ADMIN_USERNAME=
FALLBACK_ADMIN_PASSWORD=
FALLBACK_ADMIN_EMAIL=

# One-time initial admin seed, only used the first time the app connects to a
# database with zero admin users (seeding is skipped if unset)
ADMIN_SEED_USERNAME=
ADMIN_SEED_PASSWORD=
ADMIN_SEED_EMAIL=